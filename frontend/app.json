{
  "expo": {
    "name": "Guardian AI",
    "slug": "guardian-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "guardian-ai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardianai.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Track family location for safety",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Background tracking for family safety",
        "NSLocationAlwaysUsageDescription": "Continuous location for emergency alerts"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.guardianai.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Guardian AI to track location for family safety",
          "locationAlwaysPermission": "Allow background location for emergency monitoring",
          "locationWhenInUsePermission": "Allow location access to show family on map"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
